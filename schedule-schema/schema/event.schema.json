{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/FurryApp/event-schedule-schema/schema/event.schema.json",
  "title": "Event Info Schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "displayName": {
      "type": "object",
      "patternProperties": {
        "^[a-z]{2}(-[A-Z]{2})?$": { "type": "string" }
      },
      "minProperties": 1,
      "description": "Localized event names keyed by i18n language codes."
    },
    "formattedAddress": {
      "type": "string"
    },
    "startTime": {
      "type": "string",
      "format": "date-time"
    },
    "endTime": {
      "type": "string",
      "format": "date-time"
    },
    "timezone": {
      "type": "string"
    },
    "description": {
      "type": "object",
      "patternProperties": {
        "^[a-z]{2}(-[A-Z]{2})?$": { "type": "string" }
      }
    },
    "externalLinks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "object",
            "patternProperties": {
              "^[a-z]{2}(-[A-Z]{2})?$": {
                "type": "string"
              }
            }
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": ["displayName", "url"]
      }
    },
    "imageThumbnailUrl": {
      "type": "string",
      "format": "uri",
      "description": "Optional link to a thumbnail image."
    },
    "imageBannerUrl": {
      "type": "string",
      "format": "uri",
      "description": "Optional link to a larger banner image."
    },
    "x-meta": {
      "$ref": "partials/x-meta.schema.json"
    }
  },
  "required": ["id", "displayName", "startTime", "endTime", "timezone"],
  "additionalProperties": false
}
