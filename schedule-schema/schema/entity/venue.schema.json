{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/FurryApp/event-schedule-schema/schema/entity/venue.schema.json",
  "title": "Venue",
  "type": "object",
  "required": ["id", "displayName"],
  "properties": {
    "id": {
      "type": "string"
    },
    "displayName": {
      "type": "object",
      "patternProperties": {
        "^[a-z]{2}(-[A-Z]{2})?$": {
          "type": "string"
        }
      }
    },
    "formattedAddress": {
      "type": "string"
    },
    "x-meta": {
      "$ref": "../partials/x-meta.schema.json"
    }
  },
  "additionalProperties": false
}
